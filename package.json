{
  "name": "prehrajto-downloader",
  "version": "2.1.0",
  "description": "Web aplikace pro vyhledavani a stahovani filmu z prehrajto.cz",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "start:old": "node server.js",
    "dev": "nodemon server/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "prehrajto",
    "downloader",
    "scraper",
    "video"
  ],
  "author": "Patrik & Jakub; JPMP production",
  "license": "MIT"
}
