{
  "name": "prehrajto-downloader",
  "version": "2.0.0",
  "description": "Web aplikácia pre vyhľadávanie a prehrávanie filmov z prehrajto.cz",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "prehrajto",
    "downloader",
    "scraper",
    "video"
  ],
  "author": "Patrik & Jakub; JPMP production",
  "license": "MIT"
}
